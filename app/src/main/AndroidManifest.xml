<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.evacuationapp">
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application

        android:usesCleartextTraffic="true"

        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.AppCompat.Light.DarkActionBar">

        <meta-data
            android:name="com.yandex.maps.api_key"
            android:value="КЛЮЧ" />

        <activity android:name=".MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".driver.CurrentOrderActivity" />
        <activity android:name=".driver.DriverHistoryActivity" />
        <activity android:name=".driver.AvailableOrdersActivity" />
        <activity android:name=".auth.LoginActivity" />
        <activity android:name=".auth.RoleSelectionActivity" />
        <activity android:name=".client.ClientMainActivity" />
        <activity android:name=".driver.DriverMainActivity" />
        <activity android:name=".client.CreateOrderActivity" />
        <activity android:name=".client.TrackOrderActivity" />
        <activity android:name=".client.HistoryActivity" />

    </application>

</manifest>